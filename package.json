{
  "name": "xiaok",
  "version": "0.6.3",
  "description": "面向云之家开发者的 AI 编程 CLI",
  "type": "module",
  "bin": {
    "xiaok": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs'); if(process.platform!=='win32' && fs.existsSync('dist/index.js')) fs.chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsx src/index.ts",
    "hygiene:check": "node scripts/check-repo-hygiene.mjs",
    "test": "npm run test:sandbox",
    "test:full": "vitest run",
    "test:watch": "vitest",
    "test:sandbox:build": "tsc -p tsconfig.tests.json && node -e \"const fs=require('fs'); const pkg=JSON.parse(fs.readFileSync('package.json','utf8')); fs.mkdirSync('.test-dist',{recursive:true}); fs.writeFileSync('.test-dist/package.json', JSON.stringify({version:pkg.version,type:'module'}, null, 2));\"",
    "test:sandbox:run": "node -r ./tests/support/vite-net-use-patch.cjs ./node_modules/vitest/vitest.mjs run --config vitest.sandbox.config.mjs --configLoader runner",
    "test:sandbox": "npm run test:sandbox:build && npm run test:sandbox:run",
    "test:autonomy": "vitest run tests/agent/autonomy-test-cases.test.ts",
    "test:autonomy:check": "npx tsx tests/agent/autonomy-check.ts",
    "eval:run": "node benchmark/run.mjs",
    "eval:quick": "node benchmark/run.mjs --runs 1 --tasks aut-rename,eff-simple-qa,eff-math",
    "worktree:new": "node scripts/new-worktree.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.8.1",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "lodash-es": "^4.17.21",
    "openai": "^4.77.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "data"
  ]
}
