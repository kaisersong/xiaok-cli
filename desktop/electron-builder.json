{
  "appId": "com.xiaok.desktop",
  "productName": "xiaok",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "mac": {
    "target": ["dir", "dmg", "zip"],
    "icon": "build/icon.icns",
    "category": "public.app-category.productivity",
    "publish": {
      "provider": "github",
      "owner": "kaisersong",
      "repo": "xiaok-cli"
    }
  },
  "win": {
    "target": ["nsis", "portable"],
    "publish": {
      "provider": "github",
      "owner": "kaisersong",
      "repo": "xiaok-cli"
    }
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "publish": {
      "provider": "github",
      "owner": "kaisersong",
      "repo": "xiaok-cli"
    }
  }
}
