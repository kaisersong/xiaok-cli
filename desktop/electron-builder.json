{
  "appId": "com.xiaok.desktop",
  "productName": "xiaok",
  "npmRebuild": false,
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../../kswarm/src",
      "to": "services/kswarm/src",
      "filter": ["**/*.js", "**/*.json", "!**/node_modules/**"]
    },
    {
      "from": "../../kswarm/scripts",
      "to": "services/kswarm/scripts",
      "filter": ["**/*.js", "!**/node_modules/**", "!**/auto-worker.js"]
    },
    {
      "from": "overrides/kswarm/windows-xiaok-launch.js",
      "to": "services/kswarm/scripts/windows-xiaok-launch.js"
    },
    {
      "from": ".generated/kswarm/scripts/auto-worker.js",
      "to": "services/kswarm/scripts/auto-worker.js"
    },
    {
      "from": "../../kswarm/package.json",
      "to": "services/kswarm/package.json"
    },
    {
      "from": "../../kswarm/node_modules/ws",
      "to": "services/kswarm/node_modules/ws",
      "filter": ["**/*"]
    },
    {
      "from": "../../intent-broker/src",
      "to": "services/intent-broker/src",
      "filter": ["**/*.js", "**/*.json", "!**/node_modules/**"]
    },
    {
      "from": "../../intent-broker/package.json",
      "to": "services/intent-broker/package.json"
    },
    {
      "from": "../../intent-broker/adapters",
      "to": "services/intent-broker/adapters",
      "filter": ["**/*", "!**/node_modules/**"]
    },
    {
      "from": "../../intent-broker/node_modules/ws",
      "to": "services/intent-broker/node_modules/ws",
      "filter": ["**/*"]
    },
    {
      "from": "../../kai-xiaok-plugins/plugins/kai-report-creator",
      "to": "bundled-plugins/kai-report-creator",
      "filter": [
        "plugin.json",
        "skills/**/*",
        "mcp-servers/report-renderer/dist/server.bundle.js",
        "mcp-servers/report-renderer/dist/themes/**/*"
      ]
    },
    {
      "from": "../../kai-xiaok-plugins/plugins/kai-slide-creator",
      "to": "bundled-plugins/kai-slide-creator",
      "filter": [
        "plugin.json",
        "skills/**/*",
        "references/**/*",
        "schemas/**/*",
        "mcp-servers/slide-renderer/**/*.py",
        "bundled-wheels/**/*"
      ]
    },
    {
      "from": "../../kai-xiaok-plugins/plugins/cua-computer-use",
      "to": "bundled-plugins/cua-computer-use",
      "filter": [
        "plugin.json",
        "skills/**/*"
      ]
    }
  ],
  "publish": {
    "provider": "github",
    "owner": "kaisersong",
    "repo": "xiaok-cli",
    "releaseType": "release"
  },
  "mac": {
    "target": ["dir", "dmg", "zip"],
    "icon": "build/icon.icns",
    "category": "public.app-category.productivity"
  },
  "win": {
    "target": ["nsis", "portable"],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "artifactName": "${productName}-setup-${version}.${ext}"
  },
  "portable": {
    "artifactName": "${productName}-portable-${version}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"]
  }
}
