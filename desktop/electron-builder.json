{
  "appId": "com.xiaok.desktop",
  "productName": "xiaok",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "publish": {
    "provider": "github",
    "owner": "kaisersong",
    "repo": "xiaok-cli",
    "releaseType": "release"
  },
  "mac": {
    "target": ["dir", "dmg", "zip"],
    "icon": "build/icon.icns",
    "category": "public.app-category.productivity"
  },
  "win": {
    "target": ["nsis", "portable"],
    "icon": "build/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "artifactName": "${productName}-setup-${version}.${ext}"
  },
  "portable": {
    "artifactName": "${productName}-portable-${version}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"]
  }
}
