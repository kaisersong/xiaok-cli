{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["renderer/src/*"],
      "@arkloop/shared": ["renderer/src/shared/index.ts"],
      "@arkloop/shared/*": ["renderer/src/shared/*"]
    }
  },
  "include": [
    "renderer/**/*.ts",
    "renderer/**/*.tsx"
  ]
}
